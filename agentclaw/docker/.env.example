# ============================================
# AgentClaw Docker 环境变量配置
# 面向用户的项目 .env 由 agentclaw/env_config.py 统一生成
# 这里仅保留 Docker 启动脚本常用覆盖项，不作为完整配置清单
# 基础设施地址 (PG_HOST, REDIS_HOST) 由 docker-compose.yml 覆盖
# 请按需修改密码和业务参数
# LLM 模型配置请编辑项目目录下的 models.json
# ============================================

# =====================
# 项目目录
# =====================
# 智能体项目目录（包含 server.py、skills/、models.json 等）
# agentclaw serve 会在此目录下查找 server.py 并加载工作流
# 相对路径基于启动命令的当前目录，建议使用绝对路径
PROJECT_DIR=.

# =====================
# 数据目录（可选）
# =====================
# 统一运行时数据根目录；agentclaw up 配置后会同步派生以下本地与 Docker 存储路径
# 留空时本地文件使用项目目录，Docker 基础设施使用 named volumes
# AGENTCLAW_DATA_DIR=/path/to/agentclaw-data
# Docker 存储类型：volume 或 bind；使用自定义路径时设为 bind
# AGENTCLAW_DOCKER_STORAGE_TYPE=bind
# AGENTCLAW_DOCKER_PGDATA_DIR=/path/to/agentclaw-data/docker/postgres
# AGENTCLAW_DOCKER_REDISDATA_DIR=/path/to/agentclaw-data/docker/redis
# AGENTCLAW_DOCKER_ETCDDATA_DIR=/path/to/agentclaw-data/docker/etcd
# AGENTCLAW_DOCKER_MINIODATA_DIR=/path/to/agentclaw-data/docker/minio
# AGENTCLAW_DOCKER_MILVUSDATA_DIR=/path/to/agentclaw-data/docker/milvus

# =====================
# Docker 服务端口（可选）
# =====================
# AgentClaw 服务端口由 FA_PORT 或 agentclaw up -p 指定；以下端口用于 Docker 基础设施映射到宿主机。
# PG_PORT=5432
# REDIS_PORT=6379
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MILVUS_PORT=19530
# MILVUS_HTTP_PORT=9091
# ADMINER_PORT=8080

# =====================
# 认证配置
# =====================
# 管理后台 Token，访问 /admin API 需要此 Token（不设置会自动生成）
# ADMIN_TOKEN=your-admin-token
# 工作流 API Key，调用 /api/workflow/run 需要此 Key（不设置会自动生成）
# WORKFLOW_API_KEY=sk-your-workflow-key

# =====================
# PostgreSQL 数据库
# =====================
# 数据库主机地址（Docker 环境中指向 postgres 服务名）
PG_HOST=postgres
# 数据库端口
PG_PORT=5432
# 数据库用户名
PG_USER=postgres
# 数据库密码（生产环境请修改为强密码）
PG_PASSWORD=agentclaw
# 数据库名称
PG_DATABASE=agentclaw
# 连接池最小连接数
PG_POOL_MIN_SIZE=2
# 连接池最大连接数
PG_POOL_MAX_SIZE=10

# =====================
# Redis
# =====================
# Redis 主机地址（Docker 环境中指向 redis 服务名）
REDIS_HOST=redis
# Redis 端口
REDIS_PORT=6379
# Redis 密码（默认无密码，生产环境建议设置）
REDIS_PASSWORD=
# Redis 连接池最大连接数
REDIS_POOL_MAX_CONNECTIONS=20

# =====================
# 工作流配置
# =====================
# 工作流执行超时时间（秒）
WORKFLOW_TIMEOUT=300
# LangGraph 递归深度限制
WORKFLOW_RECURSION_LIMIT=50
# LLM 工具调用最大轮数（0 表示不限制）
MAX_TOOL_ROUNDS=0
# 上下文保留的最大消息数（0 表示不限制）
MAX_CONTEXT_MESSAGES=0
# 工具返回结果最大长度（字符数）
TOOL_RESULT_MAX_LENGTH=20000
# 单条消息最大长度（0 表示不限制）
MAX_MESSAGE_LENGTH=0

# =====================
# 文件上传
# =====================
# 上传文件存储目录（相对于项目目录）
UPLOAD_DIR=./.uploads
# 单文件最大上传大小（MB）
MAX_UPLOAD_SIZE_MB=20

# =====================
# 知识库 / Milvus
# =====================
# 是否启用知识库
KNOWLEDGEBASE_ENABLED=true
# 知识库存储目录（原始文件与解析结果）
KNOWLEDGEBASE_STORAGE_DIR=./.knowledgebase
# 解析缓存目录
KNOWLEDGEBASE_PARSER_CACHE_DIR=./.knowledgebase/parsed
# 知识库后端
KNOWLEDGEBASE_BACKEND=milvus
# 默认检索模式：hybrid / dense / keyword
KNOWLEDGEBASE_RETRIEVAL_MODE=hybrid
# 是否优先使用 Milvus built-in hybrid search
KNOWLEDGEBASE_PREFER_BUILTIN_HYBRID=true
# Dense 候选放大倍数（fallback 路径）
KNOWLEDGEBASE_DENSE_CANDIDATE_MULTIPLIER=3
# Keyword 候选放大倍数（fallback 路径）
KNOWLEDGEBASE_KEYWORD_CANDIDATE_MULTIPLIER=3
# Rerank 候选放大倍数（用于重排前扩大召回）
KNOWLEDGEBASE_RERANK_CANDIDATE_MULTIPLIER=3
# 默认 top_k
KNOWLEDGEBASE_DEFAULT_TOP_K=8
# 文本切分大小
KNOWLEDGEBASE_CHUNK_SIZE=1200
# 文本切分重叠
KNOWLEDGEBASE_CHUNK_OVERLAP=200
# Milvus gRPC 端口映射到宿主机；Agent 默认在宿主机运行时连接此端口
MILVUS_PORT=19530
# Milvus HTTP/metrics 端口映射；端口冲突时可改为 9092 等
MILVUS_HTTP_PORT=9091
# Milvus 地址统一从 .env 提供；当前 compose 只托管基础设施，Agent 默认在宿主机运行
MILVUS_URI=http://127.0.0.1:19530
# 如果 Agent 也运行在同一 compose 网络中，可改为 http://milvus:19530
# Milvus Token（若未启用鉴权可留空）
MILVUS_TOKEN=
# Milvus collection 前缀
MILVUS_COLLECTION_PREFIX=agentclaw_kb
# 向量相似度度量
MILVUS_METRIC_TYPE=COSINE
# 稠密索引类型
MILVUS_INDEX_TYPE=AUTOINDEX

# =====================
# 定时任务调度器
# =====================
# 是否启用调度器
SCHEDULER_ENABLED=true
# 调度器时区
SCHEDULER_TIMEZONE=Asia/Shanghai
# 调度器最大并发工作线程数
SCHEDULER_MAX_WORKERS=10
# 错过的任务是否合并执行
SCHEDULER_COALESCE=true
# 同一任务最大并发实例数
SCHEDULER_MAX_INSTANCES=1
