# AgentClaw Examples Environment Variables
# 面向用户的项目 .env 由 agentclaw/env_config.py 统一生成：
#   agentclaw init / agentclaw up
# 这里仅保留示例运行时常用的快速覆盖项，不作为完整配置清单。

# Server
PORT=8000
HOST=0.0.0.0

# Auth tokens (temporary values are generated at startup if omitted)
# ADMIN_TOKEN=your-secure-token
# WORKFLOW_API_KEY=sk-your-workflow-key
# MCP_TOKEN=your-mcp-token

# PostgreSQL (optional - for state persistence and tracing)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=password
# PG_DATABASE=agentclaw

# Redis (optional - for multi-instance prompt sync)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Knowledge Base example
# EXAMPLES_KNOWLEDGEBASE_ID=your-knowledgebase-id
